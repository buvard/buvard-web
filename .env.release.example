# Renseigne ces valeurs puis renomme en .env.release (déjà dans .gitignore).
# Utilisé uniquement par scripts/release.mjs pour push une mise à jour OTA.

# URL de ton API Buvard (sans slash final)
API_URL=https://api.buvard.app

# JWT Clerk d'un utilisateur ayant role=admin en DB
# (récupérable depuis dashboard.clerk.com -> Session token, ou via getToken() en dev)
ADMIN_JWT=eyJ...
