{
  "name": "buvard-web",
  "private": true,
  "version": "1.3.2",
  "type": "module",
  "scripts": {
    "dev": "vite --mode staging",
    "dev:local": "vite",
    "postinstall": "patch-package",
    "build": "tsc -b && vite build",
    "build:staging": "tsc -b && vite build --mode staging",
    "build:local": "tsc -b && vite build --mode development",
    "lint": "eslint . --ignore-pattern 'android/**' --ignore-pattern 'ios/**'",
    "preview": "vite preview",
    "cap:sync": "npm run build && cap sync",
    "cap:android": "npm run build && cap sync android && cap open android",
    "cap:android:staging": "npm run build:staging && cap sync android && cap open android",
    "cap:android:local": "npm run build:local && cap sync android && cap open android",
    "cap:ios": "npm run build && cap sync ios && cap open ios",
    "cap:run:android": "npm run build && cap run android --flavor prod",
    "cap:run:android:staging": "npm run build:staging && cap run android --flavor staging",
    "cap:run:android:local": "npm run build:local && cap run android --flavor local",
    "cap:run:ios": "npm run build && cap run ios",
    "cap:run:ios:staging": "npm run build:staging && cap run ios --scheme \"App Staging\"",
    "cap:run:ios:local": "npm run build:local && cap run ios --scheme \"App Staging\"",
    "release:prod": "npm run build && node scripts/release.mjs --target prod",
    "release:staging": "npm run build:staging && node scripts/release.mjs --target staging",
    "version:patch": "node scripts/version.mjs patch",
    "version:minor": "node scripts/version.mjs minor",
    "version:major": "node scripts/version.mjs major"
  },
  "dependencies": {
    "@capacitor-community/camera-preview": "^8.0.1",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/core": "^8.3.4",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-updater": "^8.47.3",
    "@tanstack/react-query": "^5.100.14",
    "better-auth": "^1.6.11",
    "better-auth-capacitor": "^0.3.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.15.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/archiver": "^7.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "archiver": "^8.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
